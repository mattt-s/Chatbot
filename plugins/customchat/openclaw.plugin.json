{
  "id": "customchat",
  "name": "Custom Chat",
  "version": "0.1.0",
  "channels": [
    "customchat"
  ],
  "description": "Custom Chat messaging channel backed by the ChatBot app.",
  "configSchema": {
    "type": "object",
    "additionalProperties": false,
    "properties": {
      "authToken": {
        "type": "string",
        "minLength": 1
      },
      "bridgePort": {
        "type": "integer",
        "minimum": 1
      },
      "accounts": {
        "type": "object",
        "additionalProperties": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "authToken": {
              "type": "string",
              "minLength": 1
            },
            "bridgePort": {
              "type": "integer",
              "minimum": 1
            }
          },
          "required": [
            "authToken"
          ]
        }
      }
    },
    "required": [
      "authToken"
    ]
  },
  "uiHints": {
    "authToken": {
      "label": "Auth Token",
      "sensitive": true
    },
    "bridgePort": {
      "label": "Bridge Port",
      "placeholder": "3001"
    }
  }
}
